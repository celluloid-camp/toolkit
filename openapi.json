{
  "openapi": "3.1.0",
  "info": {
    "title": "Celluloid Video Analysis API",
    "version": "1.11.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health Check",
        "description": "Health check endpoint",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/job/create": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Create a processing job (object_detect or scene_detect)",
        "description": "Create a video processing job. The job_type field selects which\nprocessing pipeline to run, and params holds type-specific options.",
        "operationId": "create_job",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateJobResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/status/{job_id}": {
      "get": {
        "tags": [
          "status"
        ],
        "summary": "Get the status of a job",
        "description": "Get the status of a processing job",
        "operationId": "get_job_status",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/job/{job_id}/results": {
      "get": {
        "tags": [
          "results"
        ],
        "summary": "Get the results of a completed job",
        "operationId": "get_job_results",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResultsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "job-completed": {
      "post": {
        "tags": [
          "webhooks"
        ],
        "summary": "Job Completed",
        "description": "When a job is completed, we'll send you a POST request with this\ndata to the URL that you register for the event `job-completed` in the dashboard.",
        "operationId": "job_completedjob_completed_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobCompletedWebhook"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BoundingBoxModel": {
        "properties": {
          "x": {
            "type": "integer",
            "title": "X"
          },
          "y": {
            "type": "integer",
            "title": "Y"
          },
          "width": {
            "type": "integer",
            "title": "Width"
          },
          "height": {
            "type": "integer",
            "title": "Height"
          }
        },
        "type": "object",
        "required": [
          "x",
          "y",
          "width",
          "height"
        ],
        "title": "BoundingBoxModel"
      },
      "CreateJobRequest": {
        "properties": {
          "job_type": {
            "$ref": "#/components/schemas/JobType"
          },
          "external_id": {
            "type": "string",
            "title": "External Id",
            "description": "Project identifier"
          },
          "video_url": {
            "type": "string",
            "title": "Video Url",
            "description": "URL or path to video file"
          },
          "callback_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Callback Url",
            "description": "Callback URL for job completion notifications"
          },
          "params": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ObjectDetectParams"
              },
              {
                "$ref": "#/components/schemas/SceneDetectParams"
              },
              {
                "$ref": "#/components/schemas/TranscribeParams"
              }
            ],
            "title": "Params"
          }
        },
        "type": "object",
        "required": [
          "job_type",
          "external_id",
          "video_url"
        ],
        "title": "CreateJobRequest"
      },
      "CreateJobResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "job_type": {
            "$ref": "#/components/schemas/JobType"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "queue_position": {
            "type": "integer",
            "title": "Queue Position"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "callback_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Callback Url"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "job_type",
          "status",
          "queue_position",
          "message"
        ],
        "title": "CreateJobResponse"
      },
      "DetectionFrameModel": {
        "properties": {
          "frame_idx": {
            "type": "integer",
            "title": "Frame Idx"
          },
          "timestamp": {
            "type": "number",
            "title": "Timestamp"
          },
          "objects": {
            "items": {
              "$ref": "#/components/schemas/DetectionObjectModel"
            },
            "type": "array",
            "title": "Objects"
          }
        },
        "type": "object",
        "required": [
          "frame_idx",
          "timestamp",
          "objects"
        ],
        "title": "DetectionFrameModel"
      },
      "DetectionObjectModel": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "class_name": {
            "type": "string",
            "title": "Class Name"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "bbox": {
            "$ref": "#/components/schemas/BoundingBoxModel"
          },
          "thumbnail": {
            "type": "string",
            "title": "Thumbnail"
          }
        },
        "type": "object",
        "required": [
          "id",
          "class_name",
          "confidence",
          "bbox",
          "thumbnail"
        ],
        "title": "DetectionObjectModel"
      },
      "DetectionResultsModel": {
        "properties": {
          "result_type": {
            "type": "string",
            "const": "object_detect",
            "title": "Result Type",
            "default": "object_detect"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "metadata": {
            "$ref": "#/components/schemas/ResultsMetadataModel"
          },
          "frames": {
            "items": {
              "$ref": "#/components/schemas/DetectionFrameModel"
            },
            "type": "array",
            "title": "Frames"
          }
        },
        "type": "object",
        "required": [
          "version",
          "metadata",
          "frames"
        ],
        "title": "DetectionResultsModel"
      },
      "DetectionStatisticsModel": {
        "properties": {
          "total_detections": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Detections"
          },
          "person_detections": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Person Detections"
          },
          "person_with_face": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Person With Face"
          },
          "person_without_face": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Person Without Face"
          },
          "other_detections": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Other Detections"
          },
          "class_counts": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "integer"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Class Counts"
          }
        },
        "type": "object",
        "title": "DetectionStatisticsModel"
      },
      "DiarizationSegmentModel": {
        "properties": {
          "start": {
            "type": "number",
            "title": "Start"
          },
          "end": {
            "type": "number",
            "title": "End"
          },
          "speaker": {
            "type": "string",
            "title": "Speaker"
          }
        },
        "type": "object",
        "required": [
          "start",
          "end",
          "speaker"
        ],
        "title": "DiarizationSegmentModel"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "version": {
            "type": "string",
            "title": "Version"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "job_stats": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/JobStats"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "version",
          "status",
          "timestamp"
        ],
        "title": "HealthResponse"
      },
      "JobCompletedWebhook": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "external_id": {
            "type": "string",
            "title": "External Id"
          },
          "job_type": {
            "type": "string",
            "title": "Job Type"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "external_id",
          "job_type",
          "status",
          "timestamp"
        ],
        "title": "JobCompletedWebhook"
      },
      "JobResultsResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "job_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Type"
          },
          "data": {
            "anyOf": [
              {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/DetectionResultsModel"
                  },
                  {
                    "$ref": "#/components/schemas/SceneDetectResultsModel"
                  },
                  {
                    "$ref": "#/components/schemas/TranscribeResultsModel"
                  }
                ],
                "discriminator": {
                  "propertyName": "result_type",
                  "mapping": {
                    "object_detect": "#/components/schemas/DetectionResultsModel",
                    "scene_detect": "#/components/schemas/SceneDetectResultsModel",
                    "transcribe": "#/components/schemas/TranscribeResultsModel"
                  }
                }
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "JobResultsResponse"
      },
      "JobStats": {
        "properties": {
          "queued": {
            "type": "integer",
            "title": "Queued"
          },
          "processing": {
            "type": "integer",
            "title": "Processing"
          },
          "completed": {
            "type": "integer",
            "title": "Completed"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          }
        },
        "type": "object",
        "required": [
          "queued",
          "processing",
          "completed",
          "failed"
        ],
        "title": "JobStats"
      },
      "JobStatusResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "external_id": {
            "type": "string",
            "title": "External Id"
          },
          "job_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Type"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "progress": {
            "type": "number",
            "title": "Progress"
          },
          "queue_position": {
            "type": "integer",
            "title": "Queue Position",
            "default": 0
          },
          "estimated_wait_time": {
            "type": "string",
            "title": "Estimated Wait Time",
            "default": "00:00:00"
          },
          "start_time": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Time"
          },
          "end_time": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Time"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "external_id",
          "status",
          "progress"
        ],
        "title": "JobStatusResponse"
      },
      "JobType": {
        "type": "string",
        "enum": [
          "object_detect",
          "scene_detect",
          "transcribe"
        ],
        "title": "JobType"
      },
      "ObjectDetectParams": {
        "properties": {
          "similarity_threshold": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Similarity Threshold",
            "description": "Similarity threshold for object tracking",
            "default": 0.5
          },
          "analysis_fps": {
            "type": "number",
            "maximum": 60.0,
            "exclusiveMinimum": 0.0,
            "title": "Analysis Fps",
            "description": "Frames per second to analyse (default 1)",
            "default": 1.0
          }
        },
        "type": "object",
        "title": "ObjectDetectParams"
      },
      "ProcessingMetadataModel": {
        "properties": {
          "start_time": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Time"
          },
          "end_time": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Time"
          },
          "duration_seconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Seconds"
          },
          "frames_processed": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frames Processed"
          },
          "frames_with_detections": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frames With Detections"
          },
          "processing_speed": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Processing Speed"
          },
          "detection_statistics": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DetectionStatisticsModel"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "title": "ProcessingMetadataModel"
      },
      "ResultsMetadataModel": {
        "properties": {
          "video": {
            "$ref": "#/components/schemas/VideoMetadataModel"
          },
          "sprite": {
            "$ref": "#/components/schemas/SpriteMetadataModel"
          },
          "processing": {
            "$ref": "#/components/schemas/ProcessingMetadataModel"
          }
        },
        "type": "object",
        "required": [
          "video",
          "sprite",
          "processing"
        ],
        "title": "ResultsMetadataModel"
      },
      "SceneDetectParams": {
        "properties": {
          "threshold": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Threshold",
            "description": "Content detection sensitivity threshold",
            "default": 30.0
          }
        },
        "type": "object",
        "title": "SceneDetectParams"
      },
      "SceneDetectResultsModel": {
        "properties": {
          "result_type": {
            "type": "string",
            "const": "scene_detect",
            "title": "Result Type",
            "default": "scene_detect"
          },
          "total_scenes": {
            "type": "integer",
            "title": "Total Scenes"
          },
          "scenes": {
            "items": {
              "$ref": "#/components/schemas/SceneInfoModel"
            },
            "type": "array",
            "title": "Scenes"
          },
          "sprite_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sprite Url"
          },
          "sprite_fragments": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sprite Fragments"
          }
        },
        "type": "object",
        "required": [
          "total_scenes",
          "scenes"
        ],
        "title": "SceneDetectResultsModel"
      },
      "SceneInfoModel": {
        "properties": {
          "scene_id": {
            "type": "integer",
            "title": "Scene Id"
          },
          "start_time": {
            "type": "string",
            "title": "Start Time"
          },
          "end_time": {
            "type": "string",
            "title": "End Time"
          },
          "start_seconds": {
            "type": "number",
            "title": "Start Seconds"
          },
          "end_seconds": {
            "type": "number",
            "title": "End Seconds"
          },
          "duration_seconds": {
            "type": "number",
            "title": "Duration Seconds"
          },
          "sprite_fragment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sprite Fragment"
          }
        },
        "type": "object",
        "required": [
          "scene_id",
          "start_time",
          "end_time",
          "start_seconds",
          "end_seconds",
          "duration_seconds"
        ],
        "title": "SceneInfoModel"
      },
      "SpeakerSummaryModel": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "total_speaking_time_sec": {
            "type": "number",
            "title": "Total Speaking Time Sec"
          }
        },
        "type": "object",
        "required": [
          "label",
          "total_speaking_time_sec"
        ],
        "title": "SpeakerSummaryModel"
      },
      "SpriteMetadataModel": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "thumbnail_size": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Thumbnail Size"
          }
        },
        "type": "object",
        "required": [
          "url",
          "thumbnail_size"
        ],
        "title": "SpriteMetadataModel"
      },
      "TranscribeParams": {
        "properties": {
          "model_size": {
            "type": "string",
            "title": "Model Size",
            "description": "Whisper model size (tiny, base, small, medium, large-v2, large-v3)",
            "default": "small"
          },
          "device": {
            "type": "string",
            "title": "Device",
            "description": "Inference device (cpu or cuda)",
            "default": "cpu"
          },
          "compute_type": {
            "type": "string",
            "title": "Compute Type",
            "description": "Quantisation type (int8, float16, float32)",
            "default": "int8"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language",
            "description": "ISO-639-1 language code, or null for auto-detection"
          },
          "diarization_enabled": {
            "type": "boolean",
