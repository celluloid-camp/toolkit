# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_QUEUE_NAME=celluloid_video_processing
CELERY_TASK_TIMEOUT=3600
# Redis visibility timeout (seconds) for redelivering unacked tasks
CELERY_VISIBILITY_TIMEOUT=3900
FLOWER_PORT=5555
FLOWER_PERSISTENT=true
FLOWER_DB=/app/flower/flower.db

# Logging Configuration
LOG_LEVEL=INFO

# Transcription Configuration
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# WHISPER_LANGUAGE=en  # Uncomment to force a specific language (default: auto-detect)

# Diarization Configuration
DIARIZATION_ENABLED=true
# PYANNOTE_AUTH_TOKEN=hf_...  # HuggingFace token for pyannote model access
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
